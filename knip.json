{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/core": {
      "project": ["src/**/*.ts"]
    },
    "packages/engine": {
      "project": ["src/**/*.ts"]
    },
    "packages/cli": {
      "project": ["src/**/*.ts"]
    },
    "packages/recorder": {
      "project": ["src/**/*.ts"]
    },
    "packages/studio": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/create": {
      "project": ["src/**/*.js"]
    },
    "apps/docs": {
      "project": ["**/*.{ts,md}"],
      "ignoreDependencies": ["vue"]
    },
    "examples/ace-demo": {
      "entry": ["demo.ts"],
      "project": ["**/*.ts"]
    }
  }
}
