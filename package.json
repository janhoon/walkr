{
  "name": "walkr",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "dev": "pnpm -r --parallel dev",
    "knip": "knip",
    "test": "vitest run",
    "docs:dev": "pnpm --filter @walkrstudio/docs dev",
    "docs:build": "pnpm --filter @walkrstudio/docs build",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "^2.30.0",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
