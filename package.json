{
  "name": "walkr",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "docs:dev": "pnpm --filter @walkrstudio/docs dev",
    "docs:build": "pnpm --filter @walkrstudio/docs build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.2",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
