{
  "name": "walkr",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check": "biome check . && pnpm -r type-check && pnpm -r --if-present test && knip",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "pnpm -r type-check",
    "knip": "knip",
    "dev": "pnpm -r --parallel --if-present dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "knip": "^5.0.0",
    "typescript": "^5.8.2"
  }
}
